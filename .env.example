DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ANTHROPIC_API_KEY=sk-ant-api03-...
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

ETORO_ENV=demo
ETORO_PUBLIC_KEY=your_etoro_public_key
ETORO_USER_KEY=your_etoro_user_key

# Bybit (leveraged crypto futures)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TRADING_MODE=demo            # demo | live
BYBIT_TESTNET=true

PORT=3001

# OKX Demo (active)
OKX_API_KEY=your_okx_demo_api_key
OKX_SECRET_KEY=your_okx_demo_secret_key
OKX_PASSPHRASE=your_okx_demo_passphrase
OKX_TRADING_MODE=demo

# OKX Live (inactive until ready)
OKX_LIVE_API_KEY=your_okx_live_api_key
OKX_LIVE_SECRET_KEY=your_okx_live_secret_key
OKX_LIVE_PASSPHRASE=your_okx_live_passphrase

# Cron auto-scanner
SCAN_INTERVAL=0 */4 * * *          # cron expression — every 4 hours
MIN_CONVICTION=high                # low | medium | high
MAX_TRADES_PER_SCAN=3              # max auto-trades per scan cycle
